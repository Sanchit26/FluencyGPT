{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run FluencyGPT server",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\run_dev.ps1"
			],
			"isBackground": true,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Run tests",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\run_tests.ps1"
			],
			"problemMatcher": []
		},
		{
			"label": "Bootstrap venv + install deps",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"cd \"$PWD\"; if (!(Test-Path .\\.venv)) { python -m venv .venv }; .\\.venv\\Scripts\\python.exe -m pip install --upgrade pip; .\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Bootstrap venv + install deps",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"cd \"$PWD\"; if (!(Test-Path .\\.venv)) { python -m venv .venv }; .\\.venv\\Scripts\\python.exe -m pip install --upgrade pip; .\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "Continue pip install (full output)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Pip install (finalize)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt --no-input"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Pip install (complete + verify)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt --no-input; .\\.venv\\Scripts\\python.exe -c \"import flask, dotenv, speech_recognition; print('deps-ok')\""
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Verify deps import",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				".\\.venv\\Scripts\\python.exe -c \"import flask, dotenv, speech_recognition; print('deps-ok')\""
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Install aifc backport",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				".\\.venv\\Scripts\\python.exe -m pip install aifc"
			],
			"isBackground": false,
			"problemMatcher": []
		},
		{
			"label": "Install standard-aifc backport",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				".\\.venv\\Scripts\\python.exe -m pip install standard-aifc"
			],
			"isBackground": false,
			"problemMatcher": []
		}
	]
}